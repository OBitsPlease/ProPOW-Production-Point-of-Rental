{
  "name": "propor-plus",
  "version": "2.0.8",
  "description": "ProPOR+ - Production Point of Rental Plus Truck Loading",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "npm run dev:vite & sleep 4 && open -a node_modules/electron/dist/Electron.app --args $PWD",
    "dev:vite": "vite",
    "dev:electron": "open -a node_modules/electron/dist/Electron.app --args $PWD",
    "build": "vite build && electron-builder",
    "build:mac": "vite build && electron-builder --mac",
    "build:win": "vite build && electron-builder --win",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.propor.plus",
    "productName": "ProPOR+",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      { "from": "assets/splash.png", "to": "splash.png" }
    ],
    "mac": {
      "category": "public.app-category.business",
      "icon": "assets/installer/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "assets/installer/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerSidebar": "assets/installer/splash.bmp"
    },
    "dmg": {
      "background": "assets/installer/splash.png",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "publish": {
      "provider": "github",
      "owner": "OBitsPlease",
      "repo": "ProPOW-Production-Point-of-Rental"
    }
  },
  "keywords": [
    "electron",
    "truck",
    "load-planning",
    "3d"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "vite-plugin-electron": "^0.28.4",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@react-three/drei": "^9.99.7",
    "@react-three/fiber": "^8.15.19",
    "chokidar": "^3.6.0",
    "electron-updater": "^6.1.8",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.2",
    "sql.js": "^1.12.0",
    "three": "^0.162.0",
    "xlsx": "^0.18.5"
  }
}
